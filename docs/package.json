{
  "name": "devopness-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build && node scripts/post-build.mjs",
    "dev": "next dev",
    "lint": "printf '%s\\n' '🔍Linting with:' && printf '%s' '  Prettier: ' && prettier -v && printf '%s' '  ESLint: ' && eslint -v && printf '%s\\n' '' && printf '%s\\n' 'Running ESLint ...' && eslint . && printf '%s\\n' 'Running Prettier ...' && prettier --check . && printf '%s\\n' 'Running TypeScript ...' && tsc --noEmit -p tsconfig.json",
    "lint:fix": "eslint --fix . && prettier --write . && npm run lint",
    "postinstall": "fumadocs-mdx",
    "start": "next start"
  },
  "dependencies": {
    "dotenv-expand": "^12.0.3",
    "fumadocs-core": "16.6.9",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-ui": "16.6.9",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remark-directive": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.7.4",
    "prettier-plugin-multiline-arrays": "^4.1.3",
    "prettier-plugin-sort-json": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.3.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
