{
  "name": "devopness-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build && node scripts/post-build.mjs",
    "dev": "next dev",
    "lint": "printf '%s\\n' '🔍Linting with:' && printf '%s' '  Prettier: ' && prettier -v && printf '%s' '  ESLint: ' && eslint -v && printf '%s\\n' '' && printf '%s\\n' 'Running ESLint ...' && eslint . && printf '%s\\n' 'Running Prettier ...' && prettier --check . && printf '%s\\n' 'Running TypeScript ...' && tsc --noEmit -p tsconfig.json",
    "lint:fix": "eslint --fix . && prettier --write . && npm run lint",
    "postinstall": "fumadocs-mdx",
    "start": "next start"
  },
  "dependencies": {
    "dotenv-expand": "^13.0.0",
    "fumadocs-core": "16.10.7",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-ui": "16.10.7",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.7",
    "remark-directive": "^4.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@next/eslint-plugin-next": "^16.2.9",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prettier-plugin-multiline-arrays": "^4.1.9",
    "prettier-plugin-sort-json": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
