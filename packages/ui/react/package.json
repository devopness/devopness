{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@devopness/ui-react",
  "version": "2.196.0",
  "description": "Devopness Design System React Components - Painless essential DevOps to everyone",
  "keywords": [
    "Cloud Engineering",
    "Cloud Infrastructure Management",
    "Cloud Platform Engineering",
    "Configuration Management",
    "Deploy",
    "Deployment",
    "DevOps",
    "Devopness",
    "Platform Engineering",
    "Server Management",
    "Zero Downtime Deploy"
  ],
  "homepage": "https://github.com/devopness/devopness#readme",
  "bugs": {
    "url": "https://github.com/devopness/devopness/issues"
  },
  "license": "Apache-2.0",
  "author": "Devopness (https://www.devopness.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devopness/devopness.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./radix": {
      "types": "./dist/radix.d.ts",
      "import": "./dist/radix.js",
      "require": "./dist/radix.cjs"
    },
    "./radix/styles.css": "./dist/radix/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -Rf dist && tsc -b && vp build",
    "build-storybook": "NODE_ENV=production storybook build -c .storybook -o ./storybook-static",
    "lint": "vp check",
    "lint:fix": "vp check --fix",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "storybook": "storybook dev -p 6006",
    "test": "vitest"
  },
  "dependencies": {
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "@mui/styled-engine-sc": "9.1.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/themes": "^3.3.0",
    "classnames": "^2.5.1",
    "ldrs": "^1.1.9",
    "lodash": "^4.18.1",
    "material-ui-popup-state": "^5.3.7",
    "path-browserify": "^1.0.1",
    "react-icons": "^5.7.0",
    "react-select": "^5.10.2",
    "react-spinners": "^0.17.0",
    "styled-components": "^6.4.4"
  },
  "devDependencies": {
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "10.5.3",
    "@storybook/addon-docs": "10.5.3",
    "@storybook/react-vite": "10.5.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.1",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "10.5.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vite-plus": "0.2.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "styled-components": "$styled-components",
    "vitest": {
      "vite": "$vite"
    }
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
