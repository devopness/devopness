# Slack Bot Configuration
# Copy this file to .env and fill in your actual values

# Slack Bot Token (starts with xoxb-)
# Get from: https://api.slack.com/apps → OAuth & Permissions
DEVOPNESS_SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token (starts with xapp-)
# Get from: https://api.slack.com/apps → Basic Information → App-Level Tokens
DEVOPNESS_SLACK_APP_TOKEN=xapp-your-app-token-here

# Encryption Key for storing tokens securely
# Generate with: python generate_key.py
# IMPORTANT: Keep this secret! If you lose it, all encrypted tokens are unrecoverable
DEVOPNESS_ENCRYPTION_KEY=your-fernet-key-here

# Optional: Override Devopness API URL (default: https://api.devopness.com)
# DEVOPNESS_API_URL=https://api.devopness.com
